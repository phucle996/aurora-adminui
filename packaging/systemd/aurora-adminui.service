[Unit]
Description=Aurora Admin UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=-/etc/aurora/adminui.env
ExecStart=/usr/local/bin/aurora-adminui
WorkingDirectory=/var/lib/aurora/adminui
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
